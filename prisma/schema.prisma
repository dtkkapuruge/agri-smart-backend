datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Role එක හඳුන්වා දීම (මේක අලුතින් එකතු කළා)
enum Role {
  FARMER
  BUYER
  ADMIN
}

// 2. User Model එක
model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  password     String
  name         String
  role         Role           @default(FARMER)
  location     String?
  phoneNumber  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // 🚨 මේ පේළි දෙක අනිවාර්යයෙන්ම තියෙන්න ඕනේ
  farmerProfile FarmerProfile?
  buyerProfile  BuyerProfile?
}

// 3. FarmerProfile Model එක
model FarmerProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  fullName     String
  location     String
  phoneNumber  String
  createdAt    DateTime @default(now())
}

// 4. BuyerProfile Model එක
model BuyerProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  fullName     String
  location     String
  phoneNumber  String
  createdAt    DateTime @default(now())
}